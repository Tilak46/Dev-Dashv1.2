# DevDash Environment (.env)
# Copy/paste this entire file into devdash/.env, then fill in your key.
# IMPORTANT: Never commit devdash/.env.
#
# Provider selection:
# - If GEMINI_API_KEY is set, DevDash uses Google Gemini.
# - Otherwise, if OPENROUTER_API_KEY is set, DevDash uses OpenRouter.

############################
# AI Provider: Google Gemini
############################

# Get a free key from Google AI Studio.
# Do NOT paste your key into chat; keep it only in devdash/.env.
GEMINI_API_KEY=

# Optional: model override.
# If empty, DevDash will auto-pick an available model for your key via ListModels.
GEMINI_MODEL=

################################
# AI Provider: OpenRouter (Optional)
################################

# Only used if GEMINI_API_KEY is empty.
OPENROUTER_API_KEY=

# Free model options (availability changes over time):
# - qwen/qwen3-4b:free
# - meta-llama/llama-3.2-3b-instruct:free
# - mistralai/mistral-small-3.1-24b-instruct:free
# - meta-llama/llama-3.3-70b-instruct:free
# - google/gemma-3-12b-it:free
OPENROUTER_MODEL=qwen/qwen3-4b:free

############################
# API Explorer: AI route naming
############################

# If unset, it auto-enables when GEMINI_API_KEY or OPENROUTER_API_KEY exists.
API_EXPLORER_AI_NAMING=true

# Debug logs (prints AI stats/batch info into the API Explorer logs + main process console)
API_EXPLORER_AI_DEBUG=false

# Force AI naming to run (within the budget) even if fallback names already look OK.
API_EXPLORER_AI_FORCE=false

# Hard limits to protect free keys (per scan)
API_EXPLORER_AI_BUDGET_ROUTES=40
API_EXPLORER_AI_BATCH_SIZE=10
